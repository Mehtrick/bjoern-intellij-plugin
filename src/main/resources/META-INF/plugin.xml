<idea-plugin>
    <id>de.mehtrick.bjoern-intellij-plugin</id>
    <name>Bjoern Language Support</name>
    <vendor email="support@mehtrick.de" url="https://github.com/Mehtrick">Mehtrick</vendor>

    <description><![CDATA[
    IntelliJ IDEA plugin for Bjoern BDD specification language support.

    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File Type -->
        <fileType name="Bjoern File" 
                  implementationClass="de.mehtrick.bjoern.BjoernFileType" 
                  fieldName="INSTANCE" 
                  language="Bjoern" 
                  extensions="zgr"/>
        
        <!-- Language (inherits from YAML) -->
        <lang.parserDefinition language="Bjoern"
                              implementationClass="de.mehtrick.bjoern.BjoernParserDefinition"/>
        
        <!-- Syntax Highlighter -->
        <lang.syntaxHighlighterFactory language="Bjoern"
                                      implementationClass="de.mehtrick.bjoern.BjoernSyntaxHighlighterFactory"/>
        
        <!-- Formatting Model Builder for auto-indentation -->
        <lang.formatter language="Bjoern"
                       implementationClass="de.mehtrick.bjoern.BjoernFormattingModelBuilder"/>
        
        <!-- Line Indent Provider for smart indentation -->
        <lang.lineIndentProvider language="Bjoern"
                                implementationClass="de.mehtrick.bjoern.BjoernLineIndentProvider"/>
        
        <!-- Code Completion -->
        <completion.contributor language="Bjoern"
                               implementationClass="de.mehtrick.bjoern.BjoernCompletionContributor"/>
        <!-- Backup completion for YAML language (since we inherit from YAML) -->
        <completion.contributor language="yaml"
                               implementationClass="de.mehtrick.bjoern.BjoernCompletionContributor"/>

        <!-- Tab key navigation between parameter placeholders in .zgr files -->
        <editorActionHandler action="EditorTab"
                             implementationClass="de.mehtrick.bjoern.BjoernTabHandler"
                             order="first"/>
        <!-- Breadcrumb navigation for Bjoern BDD files -->
        <breadcrumbsInfoProvider implementation="de.mehtrick.bjoern.BjoernBreadcrumbsProvider"/>

        <!-- Inspection: validate Reference field URL scheme -->
        <localInspection language="Bjoern"
                         implementationClass="de.mehtrick.bjoern.BjoernReferenceInspection"
                         displayName="Invalid Reference URL scheme"
                         groupName="Bjoern"
                         enabledByDefault="true"
                         level="WARNING"/>
    </extensions>

    <actions>
        <action id="Bjoern.NewFile"
                class="de.mehtrick.bjoern.BjoernCreateFileAction"
                text="Bjoern Spec File"
                description="Creates a new Bjoern BDD specification file">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewFile"/>
        </action>
    </actions>
</idea-plugin>